{
  "title": "ZauriScore Operations Dashboard",
  "uid": "zauriscore-ops",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Scans Per Minute",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(zauriscore_requests_total{endpoint='/api/v1/scan',method='POST'}[5m]) * 60",
          "legendFormat": "Scans/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Request Latency (p95)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(zauriscore_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(zauriscore_requests_total{status=~'5..'}[5m]) / rate(zauriscore_requests_total[5m]) * 100",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(zauriscore_requests_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 5,
      "title": "API Latency Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(zauriscore_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(zauriscore_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(zauriscore_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s"
}
