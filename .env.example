# =============================================================================
# ZauriScore Environment Configuration
# Copy this file to .env and fill in all values before running the application.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
APP_NAME=ZauriScore
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Security
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://zauriscore:zauriscore_password@postgres:5432/zauriscore
POSTGRES_DB=zauriscore
POSTGRES_USER=zauriscore
POSTGRES_PASSWORD=zauriscore_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# S3 Storage
# Use AWS S3 or any S3-compatible service (MinIO, Cloudflare R2, etc.)
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=zauriscore_access_key
S3_SECRET_ACCESS_KEY=zauriscore_secret_key
S3_BUCKET_NAME=zauriscore-reports
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Blockchain APIs
# -----------------------------------------------------------------------------
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://backend:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_FREE_SCANS_PER_DAY=5
RATE_LIMIT_PRO_SCANS_PER_DAY=100

# -----------------------------------------------------------------------------
# Analysis Engine
# -----------------------------------------------------------------------------
SLITHER_TIMEOUT=120
SOLC_PATH=/usr/local/bin/solc
MAX_CONTRACT_SIZE_KB=500
